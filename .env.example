# ── Backend (set these in Render's Environment tab) ──────────────────────────

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/offer-verify?retryWrites=true&w=majority"

# Groq AI — get your key at https://console.groq.com
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# Exa AI web search — get your key at https://exa.ai
EXA_API_KEY="YOUR_EXA_API_KEY"

# CORS: your Vercel frontend URL (e.g. https://offer-verify.vercel.app)
FRONTEND_URL="https://your-app.vercel.app"

# One-time seed endpoint protection (any random string you choose)
SEED_SECRET="YOUR_RANDOM_SECRET"


# ── Frontend (set these in Vercel's Environment Variables tab) ────────────────

# Your Render backend URL — WITHOUT a trailing slash
# If this is missing, all API calls will hit Vercel and return HTML → JSON parse errors
VITE_API_URL="https://your-backend.onrender.com"
